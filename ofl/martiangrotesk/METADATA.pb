name: "Martian Grotesk"
designer: "Roman Shamin, Evil Martians"
license: "OFL"
category: "SANS_SERIF"
date_added: "2026-05-26"
fonts {
  name: "Martian Grotesk"
  style: "normal"
  weight: 400
  filename: "MartianGrotesk[wdth,wght].ttf"
  post_script_name: "MartianGrotesk-NormalRegular"
  full_name: "Martian Grotesk Normal Regular"
  copyright: "Copyright 2020 The Martian Grotesk Project Authors (https://github.com/evilmartians/grotesk)"
}
subsets: "cyrillic"
subsets: "cyrillic-ext"
subsets: "latin"
subsets: "latin-ext"
subsets: "menu"
axes {
  tag: "wdth"
  min_value: 75.0
  max_value: 200.0
}
axes {
  tag: "wght"
  min_value: 100.0
  max_value: 1000.0
}
source {
  repository_url: "https://github.com/evilmartians/grotesk"
  commit: "cf59495b2044e67d781d90d545be1e2c265f4c19"
  files {
    source_file: "OFL.txt"
    dest_file: "OFL.txt"
  }
  files {
    source_file: "fonts/variable/MartianGrotesk[wdth,wght].ttf"
    dest_file: "MartianGrotesk[wdth,wght].ttf"
  }
  branch: "main"
  config_yaml: "sources/config.yaml"
}
